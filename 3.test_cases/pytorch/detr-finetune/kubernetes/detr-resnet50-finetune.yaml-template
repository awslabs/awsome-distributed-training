apiVersion: "kubeflow.org/v1"
kind: PyTorchJob
metadata:
  name: detr-resnet50-finetune
spec:
  elasticPolicy:
    rdzvBackend: c10d
    minReplicas: 2
    maxReplicas: 36
    maxRestarts: 100
    metrics:
      - type: Resource
        resource:
          name: cpu
          target:
            type: Utilization
            averageUtilization: 80
  pytorchReplicaSpecs:
    Worker:
      replicas: $NUM_NODES
      restartPolicy: OnFailure
      template:
        metadata:
          labels:
            app: detr-resnet50-finetune
        spec:
          volumes:
          - name: fsx-storage
            persistentVolumeClaim:
              claimName: fsx-pvc
          - name: model-cache
            emptyDir:
              sizeLimit: 10Gi
          - name: shmem
            hostPath:
              path: /dev/shm
          - name: local
            hostPath:
              path: /mnt/k8s-disks/0
          nodeSelector:
            node.kubernetes.io/instance-type: "${INSTANCE_TYPE}"
          containers:
            - name: pytorch
              image: ${IMAGE_URI}
              imagePullPolicy: Always
              resources:
                requests:
                  nvidia.com/gpu: 1
                  vpc.amazonaws.com/efa: 1
                limits:
                  nvidia.com/gpu: 1
                  vpc.amazonaws.com/efa: 1
              env:
              - name: LOGLEVEL
                value: "DEBUG"
              - name: TORCH_DISTRIBUTED_DEBUG
                value: "DETAIL"
              - name: TORCH_NCCL_ENABLE_MONITORING
                value: "1"
              - name: TORCH_NCCL_TRACE_BUFFER_SIZE
                value: "20000"
              - name: TORCH_NCCL_DUMP_ON_TIMEOUT
                value: "1"
              - name: TORCH_NCCL_DEBUG_INFO_TEMP_FILE
                value: "/local/nccl_trace_rank_"
              - name: PYTORCH_CUDA_ALLOC_CONF
                value: "expandable_segments:True"
              - name: NCCL_DEBUG
                value: "INFO"
              - name: NCCL_SOCKET_IFNAME
                value: "eth0"
              - name: NCCL_SHM_USE_CUDA_MEMCPY
                value: "1"
              - name: NCCL_PROTO
                value: "simple"
              - name: TORCH_NCCL_ASYNC_ERROR_HANDLING
                value: "1"
              - name: FI_PROVIDER
                value: "efa"
              - name: FI_EFA_FORK_SAFE
                value: "1"
              - name: PYTHONPATH
                value: "/workspace/src:/workspace"
              - name: QAI_HUB_MODEL_ID
                value: "detr_resnet50"
              - name: TRANSFORMERS_CACHE
                value: "/workspace/cache/transformers"
              - name: HF_HOME
                value: "/workspace/cache/huggingface"
              command:
                - bash
                - -c
                - |
                  set -ex
                  echo "Starting DETR-ResNet50 fine-tuning setup..."

                  # Create cache directories
                  mkdir -p "/workspace/cache/transformers" "/workspace/cache/huggingface"

                  # Setup checkpoint directory
                  if [ -w "/fsx/checkpoint" ]; then
                    export CHECKPOINT_DIR="/fsx/checkpoint"
                  else
                    export CHECKPOINT_DIR="/workspace/checkpoints"
                    mkdir -p ${CHECKPOINT_DIR}
                  fi

                  # Verify QAI Hub installation
                  python3 -c "import qai_hub_models; print('QAI Hub models ready')"

                  # Pre-download DETR model to cache
                  echo "Pre-loading DETR-ResNet50 model..."
                  python3 -c "
                  from qai_hub_models.models.detr_resnet50 import Model
                  model = Model.from_pretrained()
                  print('DETR-ResNet50 model loaded successfully')
                  "

                  echo "Starting DETR object detection training..."
                  python3 -m torch.distributed.run \
                    --nproc_per_node=1 \
                    --nnodes=$NUM_NODES \
                    --node_rank=${RANK:-0} \
                    --master_addr=${MASTER_ADDR:-localhost} \
                    --master_port=${MASTER_PORT:-29500} \
                    /workspace/detr_main.py \
                    --arch=detr-resnet50 \
                    --epochs=50 \
                    --batch-size=4 \
                    --workers=2 \
                    --lr=1e-4 \
                    --weight-decay=1e-4 \
                    --pretrained \
                    --num-classes=2 \
                    --print-freq=10 \
                    /fsx/data
              volumeMounts:
                - name: fsx-storage
                  mountPath: /fsx
                - name: model-cache
                  mountPath: /workspace/cache
                - name: shmem
                  mountPath: /dev/shm
                - name: local
                  mountPath: /local
