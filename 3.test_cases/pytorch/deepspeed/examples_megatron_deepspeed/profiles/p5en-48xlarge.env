# p5en.48xlarge — 8x H200 141GB, 32 EFA, NVLink, GPUDirect RDMA
#
# MODEL ASSUMPTIONS (Llama2-7B finetuning):
#   TP=4, PP=2 → 8 GPUs fully utilized
#   MBS=16 fits comfortably in 141GB VRAM
#   ZeRO stage 0 (no optimizer sharding needed)

# --- Hardware ---
export NUM_GPUS_PER_NODE=8

# --- Parallelism ---
export TP=4
export PP=2
export MICRO_BATCH_SIZE=16
export GLOBAL_BATCH_SIZE=256

# --- EFA / NCCL ---
export FI_LOG_LEVEL=1
export FI_PROVIDER=efa
export FI_EFA_USE_HUGE_PAGE=0
export NCCL_SOCKET_IFNAME="^docker,lo,veth"
export NCCL_ASYNC_ERROR_HANDLING=1
