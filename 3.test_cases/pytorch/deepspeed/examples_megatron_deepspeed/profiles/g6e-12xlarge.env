# g6e.12xlarge — 4x L40S 48GB, no EFA, no NVLink, no GPUDirect RDMA
#
# MODEL ASSUMPTIONS (Llama2-7B finetuning):
#   TP=2, PP=2 → 4 GPUs
#   MBS=8 fits in 48GB VRAM (half of the 80GB A100 value)
#   ZeRO stage 0 should work for Llama2-7B on 48GB GPUs

# --- Hardware ---
export NUM_GPUS_PER_NODE=4

# --- Parallelism ---
export TP=2
export PP=2
export MICRO_BATCH_SIZE=8
export GLOBAL_BATCH_SIZE=128

# --- EFA / NCCL ---
# No EFA on g6e
export NCCL_SOCKET_IFNAME="^docker,lo,veth,eth"
export NCCL_ASYNC_ERROR_HANDLING=1
