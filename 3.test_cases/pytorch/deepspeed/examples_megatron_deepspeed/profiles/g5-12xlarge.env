# g5.12xlarge — 4x A10G 24GB, no EFA, no NVLink, no GPUDirect RDMA
#
# MODEL ASSUMPTIONS (Llama2-7B finetuning):
#   TP=2, PP=2 → 4 GPUs (TP*PP must equal NUM_GPUS_PER_NODE for single-node)
#   MBS reduced to 4 for 24GB VRAM (from 16 on A100 80GB)
#   GBS reduced proportionally; adjust for your data parallel degree
#   May need ZeRO stage 1 or 2 if MBS=4 still OOMs; update ds_config.json
#
# Key differences from p4de/p5/p5en:
#   - 4 GPUs → TP*PP must be ≤ 4
#   - 24GB VRAM → reduce MBS significantly
#   - No EFA → remove all FI_* env vars
#   - A10G supports bf16 via Ampere tensor cores

# --- Hardware ---
export NUM_GPUS_PER_NODE=4

# --- Parallelism ---
export TP=2
export PP=2
export MICRO_BATCH_SIZE=4
export GLOBAL_BATCH_SIZE=64

# --- EFA / NCCL ---
# No EFA on g5
export NCCL_SOCKET_IFNAME="^docker,lo,veth,eth"
export NCCL_ASYNC_ERROR_HANDLING=1
