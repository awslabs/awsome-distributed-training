#!/usr/bin/env bash
# hf-cli-shim -- deterministic stand-in for `huggingface-cli download`.
#
# Used by the LIBERO recipe's property-based test suite (Property P6 --
# Download_Job idempotence, see
# `3.test_cases/pytorch/vla/openvla/openvla-oft/tests/libero/test_properties.py`)
# so the idempotence test can run without Hugging Face Hub network traffic.
#
# CLI surface
# -----------
# Mirrors the subset of `huggingface-cli download` that
# `kubernetes/libero/libero-download.yaml` actually invokes:
#
#   hf-cli-shim download <repo> \
#       --repo-type dataset \
#       --include "<suite>/*" \
#       --local-dir <path> \
#       --max-workers <n>
#
# Unknown flags (both `--flag value` and `--flag=value` forms) are tolerated
# so the shim stays forward-compatible with any extra `huggingface-cli`
# arguments the Download_Job might grow.
#
# Behavior
# --------
# 1. Parse `--include <pattern>` and strip a trailing `/*` (or `/`) to yield
#    the task-suite name.
# 2. Parse `--local-dir <path>`.
# 3. Idempotently create
#       <local-dir>/<suite>/1.0.0/dataset_info.json
#       <local-dir>/<suite>/1.0.0/<suite>-train.tfrecord-00000-of-00001
#    as empty files. Both files are only (re)created when absent, so two
#    invocations with the same arguments yield a byte-identical tree -- the
#    invariant Property P6 asserts on.
# 4. Print one log line to stdout and exit 0.

set -euo pipefail

usage() {
  cat >&2 <<'EOF'
usage: hf-cli-shim download <repo> \
         --include <suite>/* \
         --local-dir <path> \
         [--repo-type <t>] [--max-workers <n>] [...]
EOF
}

if [[ $# -lt 1 ]]; then
  usage
  exit 2
fi

subcommand="$1"
shift

if [[ "$subcommand" != "download" ]]; then
  echo "hf-cli-shim: only the 'download' subcommand is implemented (got '$subcommand')" >&2
  exit 2
fi

repo=""
include=""
local_dir=""

# Parse positional (repo) and flags. We explicitly recognise the flags the
# Download_Job uses plus a handful of common value-taking flags, and fall
# back to "ignore" for anything else so callers can add new flags without
# breaking the shim.
while [[ $# -gt 0 ]]; do
  case "$1" in
    --include)
      include="${2:?--include requires a value}"
      shift 2
      ;;
    --include=*)
      include="${1#--include=}"
      shift
      ;;
    --local-dir)
      local_dir="${2:?--local-dir requires a value}"
      shift 2
      ;;
    --local-dir=*)
      local_dir="${1#--local-dir=}"
      shift
      ;;
    --repo-type|--max-workers|--revision|--cache-dir|--token|--resume-download)
      # Known value-taking flags we do not need for staging. Consume the
      # flag and its value.
      shift 2
      ;;
    --repo-type=*|--max-workers=*|--revision=*|--cache-dir=*|--token=*|--resume-download=*)
      shift
      ;;
    --*=*)
      # Unknown `--flag=value` form: ignore.
      shift
      ;;
    --*)
      # Unknown `--flag [value]` form. If the next argv item doesn't look
      # like another flag, assume it's a value and consume both; otherwise
      # consume just the flag. Best-effort, but sufficient for the
      # Download_Job's surface.
      if [[ $# -ge 2 && "$2" != --* ]]; then
        shift 2
      else
        shift
      fi
      ;;
    *)
      # First bare positional is the repo name; subsequent ones are ignored.
      if [[ -z "$repo" ]]; then
        repo="$1"
      fi
      shift
      ;;
  esac
done

if [[ -z "$include" ]]; then
  echo "hf-cli-shim: missing required --include <suite>/*" >&2
  exit 2
fi
if [[ -z "$local_dir" ]]; then
  echo "hf-cli-shim: missing required --local-dir <path>" >&2
  exit 2
fi

# Strip trailing `/*` (or a bare trailing `/`) from the include pattern to
# recover the suite name. `huggingface-cli` accepts either
# "<suite>/*" or "<suite>/" style includes; handle both.
suite="${include%/\*}"
suite="${suite%/}"

if [[ -z "$suite" ]]; then
  echo "hf-cli-shim: could not parse suite from --include='${include}'" >&2
  exit 2
fi

version_dir="${local_dir%/}/${suite}/1.0.0"
mkdir -p "$version_dir"

info_file="${version_dir}/dataset_info.json"
shard_file="${version_dir}/${suite}-train.tfrecord-00000-of-00001"

# Only create when absent so repeat invocations do not rewrite the files.
# Both files are left empty -- the shim never writes non-deterministic
# content (timestamps, PIDs, etc.), so two runs produce a byte-identical
# tree, which is the invariant P6 asserts.
[[ -f "$info_file"  ]] || : > "$info_file"
[[ -f "$shard_file" ]] || : > "$shard_file"

echo "hf-cli-shim: staged ${repo:-<no-repo>} suite=${suite} under ${local_dir}"
