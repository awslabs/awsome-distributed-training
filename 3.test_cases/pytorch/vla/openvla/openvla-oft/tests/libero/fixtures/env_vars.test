# env_vars.test — test-only fixture for tests/libero/render_all_manifests.sh
#
# Populates every envsubst variable referenced by the manifests under
#   3.test_cases/pytorch/vla/openvla/openvla-oft/kubernetes/libero/*.yaml
# with representative placeholder values that are safe to pass to
#   kubectl apply --dry-run=client
# (i.e. client-side structural validation only; no API server contact, no
# AWS resource lookups, no real Secret resolution).
#
# Differences from kubernetes/libero/env_vars (the production template):
#
#   * No `${VAR:?msg}` assertions. Every variable is a plain
#     `export NAME=value` so that `source env_vars.test` under `set -u`
#     never aborts when a caller has a clean environment.
#
#   * Non-secret placeholders only. No HF_TOKEN or WANDB_API_KEY — those
#     flow through the `openvla-oft-secrets` Kubernetes Secret via
#     `secretKeyRef`, never through envsubst, so this fixture does not
#     need to fake them.
#
#   * Identifier-shaped placeholders (fs-/subnet-/sg- with 17 hex chars)
#     for AWS resource IDs so that any future server-side schema validation
#     keeps accepting them.
#
# Usage (from render_all_manifests.sh):
#
#     # shellcheck disable=SC1090
#     source "${SCRIPT_DIR}/fixtures/env_vars.test"
#     envsubst < "${MANIFEST_DIR}/<file>.yaml" | kubectl apply --dry-run=client -f -

# ---- Image + namespace ------------------------------------------------------
export IMAGE_URI="111122223333.dkr.ecr.us-east-1.amazonaws.com/openvla-oft:latest"
export NAMESPACE="default"

# ---- Cluster shape ----------------------------------------------------------
export INSTANCE_TYPE="p5.48xlarge"
export NUM_NODES="1"
export GPU_PER_NODE="8"
export EFA_PER_NODE="32"
export FI_PROVIDER="efa"

# ---- Storage ----------------------------------------------------------------
export DATA_PVC_NAME="openvla-oft-libero-data"
export DATA_PVC_SIZE="1200Gi"

# ---- Task suite -------------------------------------------------------------
# Pick a single valid suite from the allow-list. The DNS-safe form is the
# underscore-to-hyphen conversion used by metadata.name suffixes.
export TASK_SUITE="libero_spatial_no_noops"
export TASK_SUITE_DNS="libero-spatial-no-noops"

# ---- Training_Job extras ----------------------------------------------------
export RUN_ID_NOTE="parallel_dec--8_acts_chunk--continuous_acts--L1_regression--3rd_person_img--wrist_img--proprio_state"

# ---- W&B (API key comes from the Secret, not from here) ---------------------
export WANDB_MODE="offline"
export WANDB_ENTITY="test-entity"
export WANDB_PROJECT="openvla-oft-libero-test"

# ---- FSx -------------------------------------------------------------------
# AWS resource IDs are shaped as <prefix>-<17 lowercase hex chars> so that
# any future schema validation (e.g. a CRD or admission controller that
# pattern-matches AWS IDs) keeps accepting the fixture values.
export FSX_FILESYSTEM_ID="fs-0123456789abcdef0"
export FSX_SUBNET_ID="subnet-0123456789abcdef0"
export FSX_SECURITY_GROUP_ID="sg-0123456789abcdef0"
export FSX_DNS_NAME="fs-0123456789abcdef0.fsx.us-east-1.amazonaws.com"
export FSX_MOUNT_NAME="abcdef01"
