# p5en.48xlarge — 8x H200 141GB, 32 EFA, NVLink, GPUDirect RDMA
#
# MODEL ASSUMPTIONS:
#   Instance-driven: GPUS_PER_NODE, EFA/NCCL vars
#   Coupling: MICRO_BATCH_SIZE depends on GPU VRAM
#     ESM-1nv (BioNeMo 1.2): MBS=256 fits comfortably (80GB+ VRAM)
#     ESM-2 (BioNeMo 2.5):   MBS=2 is typical for 650M model

# --- Hardware ---
export GPUS_PER_NODE=8

# --- Training defaults ---
# ESM-1nv: MBS=256 occupies ~85% of 80GB VRAM (per original inline comment)
# H200 141GB allows even larger MBS, but 256 is already efficient.
export MICRO_BATCH_SIZE=256

# --- EFA / NCCL ---
export FI_PROVIDER=efa
export FI_EFA_USE_HUGE_PAGE=0
export NCCL_SOCKET_IFNAME="^docker,lo,veth"
export NCCL_DEBUG=INFO
