# p5.48xlarge — 8x H100 80GB, 32 EFA, NVLink, GPUDirect RDMA
#
# MODEL ASSUMPTIONS:
#   Instance-driven: GPUS_PER_NODE, EFA/NCCL vars
#   Model-driven: NUM_LAYERS, HIDDEN_SIZE, NUM_ATTENTION_HEADS, SEQ_LENGTH
#   Coupling: TP, PP, MBS, GBS depend on both instance VRAM and model size

# --- Hardware ---
export GPUS_PER_NODE=8

# --- Default parallelism ---
: "${TENSOR_PARALLEL:=8}"
: "${PIPELINE_PARALLEL:=1}"
: "${MICRO_BATCH_SIZE:=1}"

# --- EFA / NCCL ---
export FI_PROVIDER=efa
export FI_EFA_USE_HUGE_PAGE=0
export FI_EFA_SET_CUDA_SYNC_MEMOPS=0
export NCCL_SOCKET_IFNAME="^docker,lo,veth"
# H100 supports NVLS but it can be unstable in some configs — default off
export NCCL_NVLS_ENABLE=0

# --- Kubernetes resource requests ---
export GPU_PER_NODE=8
export EFA_PER_NODE=32
